# ──────────────────────────────────────────────
#  Python cache & compiled files
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# ──────────────────────────────────────────────
#  Jupyter Notebook
# ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ──────────────────────────────────────────────
#  Environment & secrets
# ──────────────────────────────────────────────
.env
.env.*
*.env
secrets.yaml
secrets.json
config.local.*

# ──────────────────────────────────────────────
#  SSH / private keys
# ──────────────────────────────────────────────
*.pem
*.key
*.p12
id_rsa
id_ed25519
id_ecdsa

# ──────────────────────────────────────────────
#  Virtual environments
# ──────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ──────────────────────────────────────────────
#  OS files
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────
#  Model / large binary output files (optional)
# ──────────────────────────────────────────────
*.h5
*.pkl
*.joblib
*.pt
*.pth

# ──────────────────────────────────────────────
#  Bokeh output (generated at runtime)
# ──────────────────────────────────────────────
chart.html
